# NakamaApi / Nakama environment configuration
# Copy to .env (dev) or .env.production (VPS). The app reads os.environ directly.

# When true, sources serve local fixtures/ instead of the network.
# Useful for development, CI, and offline deployments.
OFFLINE_MODE=0

# Cache lifetime for upstream responses (seconds)
CACHE_TTL_SECONDS=900

# Per-request timeout to upstream sites (seconds)
REQUEST_TIMEOUT=20

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=50

# If you store fixtures somewhere other than ./fixtures
# FIXTURES_DIR=/path/to/fixtures

# --- Optional infrastructure (all disabled by default) ---------------------

# Redis cache backend. When set, HTTP cache uses Redis instead of the in-memory
# dict. Leave unset to use the in-memory cache. Example: redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# API key authentication. When set, /anime /comic /novel require header
# `X-API-Key: <value>`. Leave unset for open access (dev/offline).
# API_KEY=change-me-to-a-long-random-secret

# Rate limit per client IP. Format: "<count>/<period>". Default: 60 req/min.
# Examples: 60/minute, 120/minute, 1000/hour
RATE_LIMIT=60/minute

# --- Source mirrors / helpers (production) ---------------------------------

# FlareSolverr for Cloudflare-protected HTML sources (sakuranovel, etc.)
# From Docker on this VPS: http://172.17.0.1:8191/v1
# FLARESOLVERR_URL=http://172.17.0.1:8191/v1

# Live base URLs (mirrors rotate)
# KIRYUU_BASE_URL=https://v7.kiryuu.to
# KOMIKCAST_API_BASE=https://be.komikcast.cc
# KOMIKCAST_BASE_URL=https://v3.komikcast.fit
# SAKURANOVEL_BASE_URL=https://sakuranovel.id

# Komikcast chapter IMAGES need a Bearer JWT from the SPA after login:
#   DevTools → Application → Local Storage → key "token" (must start with eyJ)
#   OR Network → be.komikcast.cc request → Request Headers → Authorization: Bearer …
# Appwrite auth (appwrite.komikcast.com) must be up for login to create the token.
# Without this, list/search/detail still work; images stay empty with a notes field.
# KOMIKCAST_TOKEN=eyJhbGciOi...

# Frontend (Next.js) — public API origin only (no secrets)
# NEXT_PUBLIC_API_BASE=https://mynakama.web.id
# Server-only (set by compose): API_KEY, API_INTERNAL_URL=http://api:8000

# Frontend base URL for reset-password / confirm-email links
PUBLIC_BASE_URL=https://app.mynakama.web.id
# Brevo SMTP config (300 emails/day free)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
# SMTP_USER=your@smtp-brevo.com
# SMTP_PASS=xsmtpsib-...
SMTP_FROM=noreply@app.mynakama.web.id
SMTP_TLS=1

